```gitignore
# Dependencies
node_modules/

# Build output
dist/
build/
coverage/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime files
pids/
*.pid
*.seed
*.pid.lock

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# TypeScript
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# ESLint cache
.eslintcache

# Prettier cache
.prettier-cache

# npm
.npm

# Yarn
.yarn/
.yarn-cache/

# pnpm
.pnpm-store/

# Temporary files
tmp/
temp/
.cache/

# Test coverage
.nyc_output/

# Docker overrides
docker-compose.override.yml

# Redis dump (if running Redis locally)
dump.rdb

# BullMQ generated files (if any local persistence is used)
bullmq-data/

# Misc
*.tgz
```
